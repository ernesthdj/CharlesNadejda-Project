}

Table "commandes" {
  "id" int [pk, not null, increment]
  "id_client" int [not null]
  "date_commande" datetime [default: `CURRENT_TIMESTAMP`]
  "date_souhaitee" date [not null]
  "type_reception" commandes_type_reception_enum [not null, default: 'retrait']
  "statut" commandes_statut_enum [not null, default: 'en_attente']
  "statut_paiement" commandes_statut_paiement_enum [not null, default: 'en_attente']
  "methode_paiement" commandes_methode_paiement_enum
  "stripe_session_id" varchar(255)
  "stripe_payment_intent" varchar(255)
  "frais_livraison" decimal(10,2) [not null, default: 0.00]
  "total_ttc" decimal(10,2) [not null]
  "total_avec_livraison" "decimal(10,2) GENERATED ALWAYS AS ((`total_ttc` + `frais_livraison`)) STORED"
  "adresse_livraison" varchar(255)
  "code_postal_livraison" varchar(10)
  "ville_livraison" varchar(100)
  "pays_livraison" varchar(50) [default: 'Belgique']
  "notes" text
  "notes_internes" text
}

Table "compositions_recettes" {
  "id_composition" int [not null]
  "id_recette" int [not null]
