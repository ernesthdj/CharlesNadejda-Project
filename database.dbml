  "id_gabarit_ref" int [not null, note: 'Gabarit pour lequel les quantitÃ©s sont Ã©crites']
  "hauteur_ref_cm" decimal(8,2) [not null, note: 'Ã‰paisseur de cette couche au gabarit de rÃ©fÃ©rence']
  "mode_scaling" pat_recettes_couche_mode_scaling_enum [note: 'NULL = utilise le dÃ©faut du type']
  "temps_preparation_min" int [not null, default: 0]
  "notes" text
  "actif" tinyint(1) [not null, default: 1]
  "created_at" datetime [default: `CURRENT_TIMESTAMP`]
}

Table "pat_recettes_couche_ingr" {
  "id" int [pk, not null, increment]
  "id_recette_couche" int [not null]
  "id_ingredient" int [not null, note: 'FK â†’ fiches_ingredients (partagÃ© choco+patisserie)']
  "quantite_ref" decimal(10,4) [not null]
  "unite" varchar(20) [not null]
}

Table "pat_types_couche" {
  "id" int [pk, not null, increment]
  "nom" varchar(100) [not null]
  "mode_scaling_defaut" pat_types_couche_mode_scaling_defaut_enum [not null, default: 'volume']
  "description" varchar(255)
  "actif" tinyint(1) [not null, default: 1]
  "created_at" datetime [default: `CURRENT_TIMESTAMP`]
}

Table "productions_compositions" {
  "id" int [pk, not null, increment]
  "id_composition" int [not null]
  "date_production" datetime [default: `CURRENT_TIMESTAMP`]
  "quantite_produite" int [not null]
  "cout_produits" decimal(10,2) [not null]
  "cout_emballage" decimal(10,2) [not null, default: 0.00]
  "frais_fixes_alloues" decimal(10,2) [not null, default: 0.00]
  "cout_total" decimal(10,2) [not null]
  "cout_unitaire" decimal(10,2) [not null]
  "notes" text
}

Table "productions_recettes" {
  "id" int [pk, not null, increment]
  "id_recette" int [not null]
  "date_production" datetime [default: `CURRENT_TIMESTAMP`]
  "quantite_produite" decimal(10,4) [not null]
  "poids_lot_reel" decimal(8,2)
  "poids_unitaire_reel" decimal(8,4)
  "cout_ingredients" decimal(10,2) [not null]
  "frais_fixes_alloues" decimal(10,2) [not null, default: 0.00]
  "cout_total" decimal(10,2) [not null]
  "cout_unitaire" decimal(10,4) [not null]
  "notes" text
}

Table "produits" {
  "id" int [pk, not null, increment]
  "id_categorie" int [not null]
  "id_composition" int
  "nom" varchar(200) [not null]
  "description" text
  "prix_ttc" decimal(10,2) [not null]
  "prix_htva" "decimal(10,2) GENERATED ALWAYS AS (round((`prix_ttc` / 1.21),2)) STORED"
  "prix_promo" decimal(10,2)
  "stock" int [not null, default: 0]
  "afficher_stock" tinyint(1) [not null, default: 0]
  "image_url" varchar(500)
  "configurable" tinyint(1) [not null, default: 0]
  "capacite_max" int
  "saisonnier" tinyint(1) [not null, default: 0]
  "saison_debut" varchar(20)
  "saison_fin" varchar(20)
  "disponible" tinyint(1) [not null, default: 1]
  "date_creation" datetime [default: `CURRENT_TIMESTAMP`]
}

Table "produits_parfums" {
  "id_produit" int [not null]
  "id_parfum" int [not null]

  Indexes {
    (id_produit, id_parfum) [pk, name: "PRIMARY"]
  }
}

Table "recettes_ingredients" {
  "id_recette" int [not null]
  "id_fiche_ingredient" int [not null]
  "quantite" decimal(10,4) [not null]

  Indexes {
    (id_recette, id_fiche_ingredient) [pk, name: "PRIMARY"]
  }
}

Table "selections_parfums" {
  "id" int [pk, not null, increment]
  "id_ligne_commande" int [not null]
  "id_parfum" int [not null]
  "quantite" int [not null, default: 1]
}

Table "sessions" {
  "id" varchar(255) [pk, not null]
  "user_id" "bigint unsigned"
  "ip_address" varchar(45)
  "user_agent" text
  "payload" longtext [not null]
  "last_activity" int [not null]

  Indexes {
    last_activity [type: btree, name: "sessions_last_activity_index"]
    user_id [type: btree, name: "sessions_user_id_index"]
  }
}

Table "stock_compositions" {
  "id" int [pk, not null, increment]
  "id_composition" int [not null]
  "id_production_composition" int [not null]
  "quantite_disponible" int [not null]
  "cout_unitaire" decimal(10,2) [not null]
  "date_production" date [not null]
  "date_dlc" date
  "statut" stock_compositions_statut_enum [not null, default: 'normal']
  "prix_promo" decimal(10,2)
}

Table "stock_produits" {
  "id" int [pk, not null, increment]
  "id_recette" int [not null]
  "id_production_recette" int [not null]
  "quantite_disponible" decimal(10,4) [not null]
  "cout_unitaire" decimal(10,4) [not null]
  "date_production" date [not null]
  "date_dlc" date [not null]
  "statut" stock_produits_statut_enum [not null, default: 'normal']
  "prix_promo" decimal(10,2)
}

Table "stocks" {
  "id" int [pk, not null, increment]
  "nom" varchar(200) [unique, not null]
  "description" text
  "actif" tinyint(1) [not null, default: 1]
  "date_creation" datetime [not null, default: `CURRENT_TIMESTAMP`]
}

Table "users" {
  "id" "bigint unsigned" [pk, not null, increment]
  "name" varchar(255) [not null]
  "email" varchar(255) [unique, not null]
  "email_verified_at" timestamp
  "password" varchar(255) [not null]
  "remember_token" varchar(100)
  "created_at" timestamp
  "updated_at" timestamp
}

Table "utilisateurs" {
  "id" int [pk, not null, increment]
  "nom" varchar(100) [not null]
  "prenom" varchar(100) [not null]
  "email" varchar(255) [unique, not null]
  "mot_de_passe" varchar(255) [not null]
  "role" utilisateurs_role_enum [not null, default: 'client']
  "telephone" varchar(20)
  "adresse" varchar(255)
  "code_postal" varchar(10)
  "ville" varchar(100)
  "date_inscription" datetime [default: `CURRENT_TIMESTAMP`]
  "actif" tinyint(1) [not null, default: 1]
}

Table "zones_livraison" {
  "id" int [pk, not null, increment]
  "nom" varchar(100) [not null]
  "pays_code" varchar(5) [not null]
  "code_postal_min" varchar(10)
  "code_postal_max" varchar(10)
  "frais" decimal(10,2) [not null]
  "delai_jours" int [not null, default: 3]
  "actif" tinyint(1) [not null, default: 1]
}

