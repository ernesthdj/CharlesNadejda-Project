APP_NAME="Charles & Nadejda"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Langue par défaut (fr ou en)
APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ──────────────────────────────────────────────
# MySQL — IMPORTANT : DB_HOST = 'mysql' (nom du service Docker)
# PAS 'localhost' ici — c'est l'app C# qui utilise localhost
# ──────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=charlesnadejda
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ──────────────────────────────────────────────
# Stripe (paiement Bancontact — mode TEST pour l'exam)
# Clés disponibles sur https://dashboard.stripe.com/test/apikeys
# ──────────────────────────────────────────────
STRIPE_KEY=pk_test_REMPLACER_PAR_VOTRE_CLE_PUBLIQUE
STRIPE_SECRET=sk_test_REMPLACER_PAR_VOTRE_CLE_SECRETE
STRIPE_WEBHOOK_SECRET=whsec_REMPLACER_PAR_LA_CLE_WEBHOOK
# Obtenir la clé webhook : stripe listen --forward-to localhost:8000/webhook/stripe

# ──────────────────────────────────────────────
# Cloudinary (stockage images produits)
# Clés disponibles sur https://cloudinary.com/console
# ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=REMPLACER_PAR_VOTRE_CLOUD_NAME
CLOUDINARY_API_KEY=REMPLACER_PAR_VOTRE_API_KEY
CLOUDINARY_API_SECRET=REMPLACER_PAR_VOTRE_API_SECRET

MAIL_MAILER=log
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@charlesnadejda.be"
MAIL_FROM_NAME="${APP_NAME}"

# AWS (non utilisé, garder pour éviter les erreurs Laravel)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
